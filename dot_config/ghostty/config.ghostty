font-size = 17
font-family = "Monaco"
macos-titlebar-style = tabs
macos-window-buttons = hidden
theme = Catppuccin Frappe
window-width = 146
window-height = 36
window-padding-x = 10
window-padding-y = 18
background-opacity = 0.8
background-blur = 20
window-colorspace = "display-p3"

window-inherit-working-directory = true
auto-update-channel = tip

keybind = super+shift+e=toggle_background_opacity
keybind = performable:ctrl+h=goto_split:left
keybind = performable:ctrl+j=goto_split:down
keybind = performable:ctrl+k=goto_split:up
keybind = performable:ctrl+l=goto_split:right
keybind = global:super+shift+ctrl+alt+t=toggle_quick_terminal

# <cmd + ,> to run ghostty +edit-config
keybind = unconsumed:super+,=text:\x1bqghostty +edit-config\x0d

custom-shader = shaders/cursor_warp.glsl
