# Make directory then change into into
mkcd() {
  mkdir -p "$1" && cd "$1"
}

# Hooks for chpwd
autoload -Uz add-zsh-hook

conda_auto_activate() {
    if [[ -f ".conda-env" ]]; then
        local env_name
        env_name="$(< .conda-env)"
        if [[ "$CONDA_DEFAULT_ENV" != "$env_name" ]]; then
            conda activate "$env_name" 2>/dev/null
        fi
    else
        if [[ "$CONDA_DEFAULT_ENV" != "base" ]]; then
            conda activate base 2>/dev/null
        fi
    fi
}

change_ls() {
    ls
}

open_nvim_config() {
    [[ "$PWD" == "$HOME/.config/nvim" ]] && nvim
}

add-zsh-hook chpwd conda_auto_activate
add-zsh-hook chpwd change_ls
add-zsh-hook chpwd open_nvim_config


