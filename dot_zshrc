# copy output: turn current buffer into `echo $(current buffer) | pbcopy` and run it
copy-output-widget() {
  BUFFER=" ($BUFFER) 2>&1 | pbcopy"
  zle accept-line
}
zle -N copy-output-widget
bindkey '^Jco' copy-output-widget

copy-input-clear-message() {
  local fd=$1

  # consume the byte/EOF and unregister the handler.
  read -r _ <&$fd
  zle -F $fd
  exec {fd}<&-

  zle -M ""
  zle -R
}

copy-input-widget() {
  if [[ -n $BUFFER ]]; then
    print -rn -- "$BUFFER" | pbcopy
    zle -M "Copied command line to clipboard"
    
    # after half a second, write to a pipe that ZLE is watching.
    exec {fd}< <(sleep 0.5)
    zle -F $fd copy-input-clear-message
  else
    zle -M "Nothing to copy"

    exec {fd}< <(sleep 0.5)
    zle -F $fd copy-input-clear-message
  fi
}

zle -N copy-input-widget
bindkey '^Jci' copy-input-widget

