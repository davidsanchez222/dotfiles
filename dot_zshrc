conda_auto_activate() {
    if [[ -f ".conda-env" ]]; then
        local env_name
        env_name="$(< .conda-env)"
        if [[ "$CONDA_DEFAULT_ENV" != "$env_name" ]]; then
            conda activate "$env_name" 2>/dev/null
        fi
    else
        if [[ "$CONDA_DEFAULT_ENV" != "base" ]]; then
            conda activate base 2>/dev/null
        fi
    fi
}

