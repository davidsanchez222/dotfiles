# fzf with actions
ff() {
  local selected action abs target_dir

  selected="$(
    fd \
      --follow \
      --exclude Applications \
      --exclude node_modules \
      --exclude Library \
      --glob '!.*/**' \
      --glob '!.config/**' \
      --glob '!.config' \
    | fzf --preview="bat --color=always {}"
  )" || return 1

  abs="${PWD}/${selected}"

  action="$(
    printf '%s\n' \
      'Open in Finder' \
      'Open in $EDITOR' \
      'Copy filepath' \
      'cd into directory' |
    fzf \
      --prompt='Action > ' \
      --height=20% \
      --reverse \
      --cycle \
      --bind='tab:down,btab:up'
  )" || return 1

  case "$action" in
    'Open in Finder')
      open -R -- "$abs"
      ;;
    'Open in $EDITOR')
      "${EDITOR:-vim}" -- "$abs"
      ;;
    'Copy filepath')
      printf '%s' "$abs" | pbcopy
      echo "Copied: $abs"
      ;;
    'cd into directory')
      if [ -d "$abs" ]; then
        cd -- "$abs" || return
      else
        target_dir="$(dirname -- "$abs")"
        cd -- "$target_dir" || return
      fi
      ;;
  esac
}



